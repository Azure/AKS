# llm-training environment variables.
# Source this file, then run ./submit.sh
#
# Variables use ${VAR:-default} so pre-existing shell values are preserved.
# Set AZURE_STORAGE_ACCOUNT_NAME before sourcing:
#   export AZURE_STORAGE_ACCOUNT_NAME=$(terraform -chdir=../../1-infrastructure/terraform output -raw storage_account_name)

export RAY_IMAGE="${RAY_IMAGE:-mcr.microsoft.com/aks/ai-runtime/ray:py3.12-ray2.55.1-cuda13.0}"
export RAY_VERSION="${RAY_VERSION:-2.55.1}"

export JOB_NAME="${JOB_NAME:-llm-training-$(date +%s)}"
export QUEUE_NAME="${QUEUE_NAME:-default}"
export CONFIGMAP_NAME="${CONFIGMAP_NAME:-llm-training-scripts}"

# 4 workers x 1 GPU each (reduce NUM_WORKERS for smaller node types)
export NUM_WORKERS="${NUM_WORKERS:-4}"

# Module 1 storage outputs
export AZURE_STORAGE_ACCOUNT_NAME="${AZURE_STORAGE_ACCOUNT_NAME:-}"
export LLM_DATA_CONTAINER="${LLM_DATA_CONTAINER:-llm-pipeline}"
export LLM_LORA_CONTAINER="${LLM_LORA_CONTAINER:-llm-pipeline}"
