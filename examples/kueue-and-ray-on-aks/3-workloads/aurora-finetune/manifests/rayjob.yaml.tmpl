apiVersion: ray.io/v1
kind: RayJob
metadata:
  name: "${JOB_NAME}"
  namespace: ray
  labels:
    kueue.x-k8s.io/queue-name: "${QUEUE_NAME}"
spec:
  suspend: true
  shutdownAfterJobFinishes: true
  ttlSecondsAfterFinished: 300

  entrypoint: python3 /home/ray/scripts/aurora_finetune.py

  runtimeEnvYAML: |
    pip:
      - --index-url https://download.pytorch.org/whl/cu121
      - --extra-index-url https://pypi.org/simple
      - torch==2.9.1
      - microsoft-aurora==1.8.0
      - transformers==5.8.1
      - peft==0.19.1
      - accelerate==1.13.0
      - safetensors==0.7.0
      - pyyaml==6.0.3
      - xarray==2026.4.0
      - azure-storage-blob==12.25.1
      - azure-identity==1.21.0
    env_vars:
      HF_HUB_DISABLE_TELEMETRY: "1"
      AZURE_STORAGE_ACCOUNT_NAME: "${AZURE_STORAGE_ACCOUNT_NAME}"
      AURORA_INPUT_CONTAINER: "${AURORA_INPUT_CONTAINER}"
      AURORA_OUTPUT_CONTAINER: "${AURORA_OUTPUT_CONTAINER}"
      AURORA_INIT_FILE: "${AURORA_INIT_FILE}"
      AURORA_TRUTH_FILE: "${AURORA_TRUTH_FILE}"
      AURORA_LEAD_HOURS: "${AURORA_LEAD_HOURS}"
      AURORA_RUN_ID: "${JOB_NAME}"
      AURORA_REQUIRE_GPU_NAME: "${AURORA_REQUIRE_GPU_NAME}"

  submitterPodTemplate:
    spec:
      restartPolicy: Never
      containers:
        - name: ray-job-submitter
          image: "${RAY_IMAGE}"
          imagePullPolicy: Always

  rayClusterSpec:
    rayVersion: "${RAY_VERSION}"
    enableInTreeAutoscaling: false

    headGroupSpec:
      rayStartParams:
        num-cpus: "0"
        dashboard-host: "0.0.0.0"
        disable-usage-stats: "true"
      template:
        metadata:
          labels:
            azure.workload.identity/use: "true"
        spec:
          serviceAccountName: ray-workload
          containers:
            - name: ray-head
              image: "${RAY_IMAGE}"
              imagePullPolicy: Always
              env:
                - name: RAY_DISABLE_DOCKER_CPU_WARNING
                  value: "1"
              ports:
                - containerPort: 6379
                  name: gcs-server
                - containerPort: 8265
                  name: dashboard
                - containerPort: 10001
                  name: client
              resources:
                limits:
                  cpu: "2"
                  memory: "8Gi"
                requests:
                  cpu: "2"
                  memory: "8Gi"
              volumeMounts:
                - name: scripts
                  mountPath: /home/ray/scripts
          volumes:
            - name: scripts
              configMap:
                name: "${CONFIGMAP_NAME}"

    workerGroupSpecs:
      - groupName: gpu-workers
        replicas: 1
        minReplicas: 1
        maxReplicas: 1
        rayStartParams:
          num-gpus: "1"
        template:
          metadata:
            labels:
              azure.workload.identity/use: "true"
          spec:
            serviceAccountName: ray-workload
            containers:
              - name: ray-worker
                image: "${RAY_IMAGE}"
                imagePullPolicy: Always
                resources:
                  limits:
                    cpu: "18"
                    memory: "160Gi"
                    nvidia.com/gpu: "1"
                  requests:
                    cpu: "18"
                    memory: "160Gi"
                    nvidia.com/gpu: "1"
                volumeMounts:
                  - name: scripts
                    mountPath: /home/ray/scripts
            volumes:
              - name: scripts
                configMap:
                  name: "${CONFIGMAP_NAME}"
