# aurora-finetune environment variables.
# Source this file, then run ./submit.sh
#
# Storage variables are outputs from Module 1:
#   terraform -chdir=../../1-infrastructure/terraform output -raw storage_account_name
#   terraform -chdir=../../1-infrastructure/terraform output -raw aurora_container_name
#
# Variables use ${VAR:-default} so pre-existing shell values are preserved.
# This means you can set AZURE_STORAGE_ACCOUNT_NAME before sourcing and it
# will not be overwritten, and ./submit.sh can safely re-source this file.

export RAY_IMAGE="${RAY_IMAGE:-mcr.microsoft.com/aks/ai-runtime/ray:py3.12-ray2.55.1-cuda13.0}"
export RAY_VERSION="${RAY_VERSION:-2.55.1}"

# Unique name for this RayJob run — generated once, preserved on re-source.
export JOB_NAME="${JOB_NAME:-aurora-finetune-$(date +%s)}"

# Kueue LocalQueue (from Module 2). Options: default, team-a, team-b
export QUEUE_NAME="${QUEUE_NAME:-default}"

# ConfigMap name (holds aurora_finetune.py)
export CONFIGMAP_NAME="${CONFIGMAP_NAME:-aurora-finetune-scripts}"

# Module 1 storage outputs — set AZURE_STORAGE_ACCOUNT_NAME before sourcing:
#   export AZURE_STORAGE_ACCOUNT_NAME=$(terraform -chdir=../../1-infrastructure/terraform output -raw storage_account_name)
export AZURE_STORAGE_ACCOUNT_NAME="${AZURE_STORAGE_ACCOUNT_NAME:-}"
export AURORA_INPUT_CONTAINER="${AURORA_INPUT_CONTAINER:-aurora}"
export AURORA_OUTPUT_CONTAINER="${AURORA_OUTPUT_CONTAINER:-aurora}"

# Default input file names (match W1.4 upload — Hurricane Ida Gulf landfall)
export AURORA_INIT_FILE="${AURORA_INIT_FILE:-init-2021-01-01-00z.npz}"
export AURORA_TRUTH_FILE="${AURORA_TRUTH_FILE:-truth-2021-01-01-06z.npz}"
