# online-serving environment variables.
# Requires a completed aurora-finetune job — set AURORA_RUN_ID to that job's JOB_NAME.
#
# Variables use ${VAR:-default} so pre-existing shell values are preserved.
# Set required vars before sourcing:
#   export AZURE_STORAGE_ACCOUNT_NAME=$(terraform -chdir=../../1-infrastructure/terraform output -raw storage_account_name)
#   export AURORA_RUN_ID=<JOB_NAME from completed aurora-finetune run>

export RAY_IMAGE="${RAY_IMAGE:-mcr.microsoft.com/aks/ai-runtime/ray:py3.12-ray2.55.1-cuda13.0}"
export RAY_VERSION="${RAY_VERSION:-2.55.1}"

export SERVICE_NAME="${SERVICE_NAME:-aurora-serve}"
export APP_NAME="${APP_NAME:-aurora}"
export ROUTE_PREFIX="${ROUTE_PREFIX:-/aurora}"
export IMPORT_PATH="${IMPORT_PATH:-aurora_serve:app}"
export CONFIGMAP_NAME="${CONFIGMAP_NAME:-aurora-serve-scripts}"

# Module 1 storage outputs
export AZURE_STORAGE_ACCOUNT_NAME="${AZURE_STORAGE_ACCOUNT_NAME:-}"
export AURORA_INPUT_CONTAINER="${AURORA_INPUT_CONTAINER:-aurora}"
export AURORA_ADAPTER_CONTAINER="${AURORA_ADAPTER_CONTAINER:-aurora}"

# JOB_NAME from the completed aurora-finetune run (e.g. aurora-finetune-1718400000)
export AURORA_RUN_ID="${AURORA_RUN_ID:-}"

# LoRA rank — must match the rank used during training (default 8)
export AURORA_LORA_RANK="${AURORA_LORA_RANK:-8}"

# Serving defaults (override per-request via POST body)
export AURORA_INIT_FILE="${AURORA_INIT_FILE:-init-2021-01-01-00z.npz}"
export AURORA_LEAD_HOURS="${AURORA_LEAD_HOURS:-6}"
export AURORA_REQUIRE_GPU_NAME="${AURORA_REQUIRE_GPU_NAME:-A100}"
