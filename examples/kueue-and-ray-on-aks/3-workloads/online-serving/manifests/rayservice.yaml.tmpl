apiVersion: ray.io/v1
kind: RayService
metadata:
  name: "${SERVICE_NAME}"
  namespace: ray
spec:
  serveConfigV2: |
    http_options:
      host: "0.0.0.0"
      port: 8000
    applications:
      - name: ${APP_NAME}
        route_prefix: ${ROUTE_PREFIX}
        import_path: ${IMPORT_PATH}
        runtime_env:
          pip:
            - --index-url https://download.pytorch.org/whl/cu121
            - --extra-index-url https://pypi.org/simple
            - torch==2.9.1
            - microsoft-aurora==1.8.0
            - transformers==5.8.1
            - peft==0.19.1
            - accelerate==1.13.0
            - safetensors==0.7.0
            - pyyaml==6.0.3
            - xarray==2026.4.0
            - azure-storage-blob==12.25.1
            - azure-identity==1.21.0
          env_vars:
            PYTHONPATH: "/home/ray/scripts"
            AZURE_STORAGE_ACCOUNT_NAME: "${AZURE_STORAGE_ACCOUNT_NAME}"
            AURORA_INPUT_CONTAINER: "${AURORA_INPUT_CONTAINER}"
            AURORA_ADAPTER_CONTAINER: "${AURORA_ADAPTER_CONTAINER}"
            AURORA_RUN_ID: "${AURORA_RUN_ID}"
            AURORA_LORA_RANK: "${AURORA_LORA_RANK}"
            AURORA_INIT_FILE: "${AURORA_INIT_FILE}"
            AURORA_LEAD_HOURS: "${AURORA_LEAD_HOURS}"
            AURORA_REQUIRE_GPU_NAME: "${AURORA_REQUIRE_GPU_NAME}"

  rayClusterConfig:
    rayVersion: "${RAY_VERSION}"
    enableInTreeAutoscaling: false

    headGroupSpec:
      rayStartParams:
        num-cpus: "4"
        num-gpus: "1"
        dashboard-host: "0.0.0.0"
        disable-usage-stats: "true"
      template:
        metadata:
          labels:
            azure.workload.identity/use: "true"
        spec:
          serviceAccountName: ray-workload
          containers:
            - name: ray-head
              image: "${RAY_IMAGE}"
              imagePullPolicy: Always
              env:
                - name: RAY_DISABLE_DOCKER_CPU_WARNING
                  value: "1"
              ports:
                - containerPort: 6379
                  name: gcs-server
                - containerPort: 8265
                  name: dashboard
                - containerPort: 8000
                  name: serve
                - containerPort: 10001
                  name: client
              resources:
                limits:
                  cpu: "20"
                  memory: "160Gi"
                  nvidia.com/gpu: "1"
                requests:
                  cpu: "20"
                  memory: "160Gi"
                  nvidia.com/gpu: "1"
              volumeMounts:
                - name: scripts
                  mountPath: /home/ray/scripts
          volumes:
            - name: scripts
              configMap:
                name: "${CONFIGMAP_NAME}"
